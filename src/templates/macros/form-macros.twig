{#
    Sets the error container
    form: (object) The Twig form variable
    message: (string) OPTIONAL A custom message to show above the error list.
#}
{% macro formErrorContainer(form, message) %}
    <div class="Message Message--failure mb-5 {% if form.errors is empty and form.paymentErrors is empty %} hidden{% endif %}">
        {% set errorMessage = form.paymentErrors is empty ? 'There was a problem with your submission. Please correct the issues below' : 'Could not process your payment' %}
        {% set errorMessage = message ? message : errorMessage %}
        <p>{{ errorMessage }}</p>
        <ul class="mb-0">
            {% for error in form.errors %}
                {% if error.message %}
                    <li>{{ error.message }}</li>
                {% elseif error.fieldName == 'ap-form-captcha' %}
                    {% if form.captcha.error %}
                        <li>Google reCAPTCHA error: {{ form.captcha.error }}</li>
                    {% elseif form.captcha.errorCode %}
                        <li>Google reCAPTCHA error: {{ form.captcha.errorCode }}</li>
                    {% endif %}
                {% endif %}
            {% endfor %}
            {% for error in form.paymentErrors %}
                <li>{{ error.message }}</li>
            {% endfor %}
        </ul>
    </div>
{% endmacro %}

{#
    Sets the error container to show only a single message. This will not loop through errors.
    Instead, it simply outputs a single error message. Useful for a login page.

    errorContainerClass: (string) The unique class for the error container div
    form: (object) The Twig form variable
    message: (string) The error message to show
#}
{% macro formErrorContainerSingleMessage(errorContainerClass, form, message) %}
    <div class="Message Message--failure mb-5 {{ errorContainerClass}}{% if form.errors is empty and form.paymentErrors is empty %} hidden{% endif %}">
        {{ message }}
    </div>
{% endmacro %}

{# Build the reCAPTCHA tag #}
{% macro captcha(form) %}
    {% if form.captcha.type == 'recaptchaV3' %}
        {# Recaptcha V3 #}
        {# Because there can be multiple reCAPTCHAs on the page, make the input class unique #}
        {% do form.captcha.makeInputUnique() %}
        {% if _page.hasJs('recaptchaV3') == false %}
            {# Include the hidden input tag, reCAPTCHA Javascript file and the Javascript promise function #}
            {{ form.captcha.tag }}
            {% do _page.registerJs('recaptchaV3') %}
        {% else %}
            {# Only output the hidden input tag as the reCAPTCHA Javascript file and the Javascript promise function have already been included on the page. #}
            {{ form.captcha.input.tag }}
        {% endif %}
    {% endif %}
{% endmacro %}

{#
    Set up the form validation and the form handler Javascript

    form: (array) The form data
    config: (array) OPTIONAL Configuration options for the form validation

    config options:
    - filesToLoad: (array) Array of additional Javascript files to load
    - filesToLoadKey: (string) The key to use for the loadjs.ready function to load additional files referenced in filesToLoad. This can be used
            in some other Javascript to run code once the files load.
    - formHandler: (string) Name of a custom form handler Javascript variable to use. The variable needs to be globally accessible.
    - formOverlayClass: (string) The class to use for the form overlay div
    - loadJsKey: (string) The key to use for the loadjs.ready function. This should reference a loadJs() key that is used in Javascript
            outside of this macro to load other files.
    - loadJsKeys: (array) Array of keys to use for the loadjs.ready function. These should reference one or more loadJs() keys that are used in Jvaascript
            outside of this macro to load other files.

    Examples:
    Basic:
    {{ macros.formHandlerJs(form) }}
    All parameters:
    {{ macros.formHandlerJs(form, {filesToLoad: ['js/stripe.js'|theme_url], formHandler: 'stripePayment', formOverlayClass: 'js-formOverlay'}) }}
    Form handler:
    <script>
        const customHandler = new FormHandler();
        // Do some other intial setup of the form handler.
        customHandler.setUseAjax();
    </script>
    {{ macros.formHandlerJs(form, {formHandler: 'customHandler'}) }}
#}
{% macro formValidateHandlerJs(form, config) %}
    {# Make sure that the config variable is an object #}
    {% set config = config ?? {} %}

    {# Set up the form overlay class #}
    {% set formOverlayClass = config.formOverlayClass ?: 'js-formOverlay' ~ random_string() %}
    <div class="FormOverlay {{ formOverlayClass }}"><div class="FormOverlay-text">Please wait&hellip;</div></div>

    {# Load for form Javascript if necessary. This holds the form validation library. #}
    {% if _page.hasJs('just-validate/just-validate.production.min.js'|theme_url) == false %}
        {% inlinejs %}
            loadjs.ready('main', {
                success: function() {
                    loadjs('{{ 'just-validate/just-validate.production.min.js'|theme_url }}', 'validate');
                }
            });
        {% endinlinejs %}
        {% do _page.registerJs('just-validate/just-validate.production.min.js'|theme_url) %}
    {% endif %}

    {% set setupFunction = 'setupForm' ~ random_string() %}
    {% set formHandlerObject = 'formHandler' ~ random_string() %}

    {% inlinejs %}
        {# Function to set up the form handler and validation #}
        function {{ setupFunction }}(formHandler) {
            formHandler.setFormSelector('.{{ form.class }}');
            formHandler.setFormOverlaySelector('.{{ formOverlayClass }}');
            {% if form.captcha.type == 'recaptchaV3' %}
                {# Because the function is passed as a string we remove "window." from the function name so that it can be called in the form class using window[functionName] #}
                formHandler.setUseRecaptchaV3('{{ form.captcha.script.function|replace('window.', '') }}', '.{{ form.captcha.input.class }}');
            {% endif %}
            formHandler.initValidation();
        }

        {# Load additional files or handle when the validation libray is loaded #}
        {% set loadJsKeys = ['validate'] %}
        {% if config.filesToLoad is iterable and config.filesToLoad|length > 0 %}
            {% set extraFilesKey = config.filesToLoadKey ?? ('formExtraFiles' ~ random_string()) %}
            {# Load the additional files #}
            loadjs.ready('validate', {
                success: function() {
                    loadjs([{% for file in config.filesToLoad %}{% if loop.first == false and loop.lsat == false %},{% endif %}'{{ file }}'{% endfor %}], '{{ extraFilesKey }}');
                }
            });
            {% set loadJsKeys = [extraFilesKey] %}
        {% endif %}
        {# Handle any extra loadJs keys #}
        {% if config.loadJsKeys is iterable and config.loadJsKeys|length > 0 %}
            {% set loadJsKeys = loadJsKeys|merge(config.loadJsKeys) %}
        {% elseif config.loadJsKeys is string %}
            {% set loadJsKeys = loadJsKeys|merge([config.loadJsKeys]) %}
        {% elseif config.loadJsKey is string %}
            {% set loadJsKeys = loadJsKeys|merge([config.loadJsKey]) %}
        {% endif %}

        {# After loading the necessary files, set up the form handler #}
        loadjs.ready({{ loadJsKeys|json }}, {
            success: function() {
                {% if config.formHandler %}
                    const {{ formHandlerObject }} = {{ config.formHandler }};
                {% else %}
                    const {{ formHandlerObject }} = new FormHandler();
                {% endif %}
                {{ setupFunction }}({{ formHandlerObject }});
            }
        });
    {% endinlinejs %}

{% endmacro %}
