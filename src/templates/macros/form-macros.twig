{#
 # Build the field label
 # field: (array) The field data
 #}
{% macro buildFieldLabel(field, labelClass, formType) %}
    {% set field.label.class = field.label.class ~ ' FormLabel' %}
    {% if formType == 'labelAboveField' %}
        {% if field.description and field.fieldType in ['checkbox', 'multiCheckbox', 'radio'] %}
            {% set field.label.class = field.label.class ~ ' FormLabel--mb0' %}
        {% endif %}
    {% endif %}
    {% if labelClass %}
        {% set field.label.class = field.label.class ~ ' ' ~ labelClass %}
    {% endif %}
    {% if field.isRequired %}
        {% set field.required = true %}
        {% set field.label.text = field.label.text ~ ' <span class="FormRequired">*</span>' %}
    {% endif %}
    {% if field.fieldType not in ['rating', 'checkbox'] %}
        {{ field.label.tag }}
    {% endif %}
{% endmacro %}

{#
 # Build a form field
 # field: (array) The field data
 #}
{% macro buildField(field) %}
    {% import 'macros/macros.twig' as macros %}
    {# Display the field description above the field if necessary #}
    {% if field.type not in ['grid', 'repeatingGrid'] %}
        {{ _self.buildFieldDescription(field, 'above') }}
    {% endif %}

    {# Add the is-invalid class to the field if there is an error #}
    {% set field.class = field.class|replace({"error": "is-invalid"}) %}

    {# Set HTML attributes based on the validation #}
    {% if field.fieldType not in ["radio", "multiCheckbox", "checkbox"] %}
        {% if field.rules %}
            {% set field.data.validate = true %}
            {% if field.fieldType == 'email' %}
                {% do field.set('data-validate-email', 'Please enter a valid email') %}
            {% elseif field.fieldType == 'number' %}
                {% do field.set('data-validate-number', true) %}
            {% endif %}
            {% for rule in field.rules %}
                {% do field.set('data-validate-' ~ rule.type|kebab, rule.message) %}
                {% if rule.type == 'min_length' %}
                    {% do field.set('data-validate-' ~ rule.type|kebab ~ '-value', rule.rule) %}
                {% endif %}
            {% endfor %}
        {% else %}
            {% if field.fieldType == 'email' %}
                {# The field isn't required, but it's an email field and should be validated #}
                {% set field.data.validate = true %}
                {% do field.set('data-validate-email', 'Please enter a valid email') %}
            {% elseif field.fieldType == 'number' %}
                {# The field isn't required, but it's a number field and should be validated #}
                {% set field.data.validate = true %}
                {% do field.set('data-validate-number', true) %}
            {% endif %}
        {% endif %}
    {% elseif field.isRequired and field.fieldType in ["radio", "multiCheckbox", "checkbox"] %}
        {# Set up the group information for required checkbox and radio fields #}
        {% set field.groupId = random_letters() %}
    {% endif %}

    {# The groupId value is used for radio and checkbox field validation with the JustValidate library #}
    {% if field.groupId %}
        {% if field.rules %}
            {% for rule in field.rules %}
                {% if rule.type == "required" %}
                    {% set requiredMessage = rule.message %}
                {% endif %}
            {% endfor %}
        {% endif %}
        <div id="{{ field.groupId }}" data-required-group="{{ requiredMessage ?? 'This field is required' }}" data-required-group-id="{{ field.groupId }}">
    {% endif %}

    {# Output the field #}
    {% if field.fieldType in ['email', 'number', 'password', 'text', 'url', 'tel'] %}
        {% set field.class = field.class ~ ' TextInput w-100' %}
        {% if field.fieldType == 'number' %}
            {% set field.class = field.class ~ ' js-numberInput' %}
            {% set field.inputmode = 'numeric' %}
            {# Because Safari internally change the field value to an empty string if the field isn't a number,
               which messes up the validation and the internal filter to force a number value, we set the input type
               as text and use the inputmode attribute to force a numeric keyboard on mobile devices. #}
            {% set field.type = 'text' %}
        {% endif %}
        {{ field.tag }}
    {%  elseif field.fieldType in ['date', 'time', 'month'] %}
        {% set field.class = field.class ~ ' TextInput' %}
        {{ field.tag }}
    {% elseif field.fieldType == 'button' %}
        {% set field.class = field.class ~ ' Button' %}
        {{ field.tag }}
    {% elseif field.fieldType == 'textarea' %}
        {% if field.size == 'small' %}
            {% set field.rows = 2 %}
        {% elseif field.size == 'medium' %}
            {% set field.rows = 5 %}
        {% elseif field.size == 'large' %}
            {% set field.rows = 10 %}
        {% endif %}
        {% set field.class = field.class ~ ' TextInput w-100' %}
        {{ field.tag }}
    {% elseif field.fieldType in ['select', 'selectMonth', 'selectDay', 'selectYear'] %}
        <div class="SelectMenu SelectMenu--{{ _core.theme.settings.selectMenuArrowType }} w-100">
            {{ field.tag }}
        </div>
    {% elseif field.fieldType == 'radio' or field.fieldType == 'multiCheckbox' %}
        {% if field.config.separator == 'space' %}
            {% for option in field.options %}
                <label class="pr-2">{{ option.tagNoLabel }} {{ option.label }}</label>
            {% endfor %}
        {% else %}
            {{ field.tag|replace({"error": "is-invalid"}) }}
        {% endif %}
    {% elseif field.fieldType == 'checkbox' %}
        <label class="Checkbox">
            {% set field.class = "Checkbox-input" %}
            {{ field.tagNoLabel }}
            <span class="Checkbox-pseudo"></span>
            {{ field.label.text }}
        </label>
    {% elseif field.fieldType == 'file' %}
        <div class="FormLabel">{{ field.label.text }}</div>
        <label for="{{ field.id }}" class="Button FileField-button">Upload File</label>
        {{ field.tag|replace({"error": "is-invalid"}) }}
    {% elseif field.fieldType == 'image' %}
        {% set field.class = field.class ~ ' FileField-input js-imageInput' %}
        {% set field.accept = '.gif,.jpg,.jpeg,.png' %}
        {% do field.set('data-for', field.id|ucfirst) %}
        {% set fileBtnText = 'Choose an image' %}
        {% set hasExistingImage = false %}
        {% if field.value %}
            {% set field.data.value = 'yes' %}
            {% set hasExistingImage = true %}
            {% set fileBtnText = 'Change image' %}
            {# Show the current image above the field #}
            <div class="mb-2 js-removeExistingImageCancelContainer hidden" data-id="{{ field.id }}">
                <button type="button" class="js-removeExistingImageCancel FileField-actionButton" data-id="{{ field.id }}">{{ macros.iconAriaHidden('undo') }}Undo remove image</button>
            </div>

            <div class="js-currentImgContainer" data-id="{{ field.id }}">
                <div class="grid g-1 align-center mb-2 nc-2">
                    <div class="col-1-2">
                        <img src="{{ field.value|file_url }}" data-id="{{ field.id }}" alt="Image" class="FileField-image">
                    </div>
                    <div class="col-1-2">
                        <button type="button" class="js-removeExistingImage FileField-actionButton FileField-actionButton--remove" data-id="{{ field.id }}">{{ macros.iconAriaHidden('trash') }}Remove</button>
                    </div>
                    {#
                        Used to pass an empty value to remove the image.
                        To remove a file pass an empty value for that field.
                        If a text or hidden input has a value for the field then that value will be used
                        when saving. However, if a file upload is done then that will override the text/hidden input value.
                    #}
                    <input type="hidden" data-name="{{ field.name }}" value="" class="js-currentImageValue" data-id="{{ field.id }}">
                </div>
            </div>
        {% endif %}
        {# Output where the new image is displayed #}
        <div class="js-newImageContainer hidden" data-id="{{ field.id }}">
            <div class="grid g-1 align-center mb-2 nc-2">
                <div class="col-1-2">
                    <img src="" alt="Image" class="FileField-image js-newImage" data-id="{{ field.id }}">
                </div>
                <div class="col-1-2">
                    <button type="button" class="js-removeNewImage FileField-actionButton FileField-actionButton--remove" data-id="{{ field.id }}"{% if hasExistingImage %} style="display: none"{% endif %}>{{ macros.iconAriaHidden('trash') }}Remove</button>
                    <button type="button" class="js-undoNewImage FileField-actionButton" data-id="{{ field.id }}"{% if !hasExistingImage %} style="display: none"{% endif %}>{{ macros.iconAriaHidden('undo') }}Undo change</button>
                </div>
            </div>
        </div>
        {# Output the upload field and button #}
        <label class="Button FileField-button" for="{{ field.id }}">
            {{ macros.iconAriaHidden('upload') }} <span class="js-fileText" data-orig="Choose an image">{{ fileBtnText }}</span>
            {{ field.tag }} {# The field is hidden #}
        </label>
    {% elseif field.fieldType == 'rating' %}
        <div class="grid g-2 nc-2">
            <div class="col-1-2 col-2-3-md col-3-4-lg w-100">
                {{ field.label.tag }}
            </div>
            <div class="col-1-2 col-1-3-md col-1-4-lg w-100">
                <div class="flex justify-end-lg align-center-lg h-100 justify-start align-start mt-1 mt-0-lg">
                    {% for option in field.options %}
                        <label class="pr-2">{{ option.tagNoLabel }} {{ option.label }}</label>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% elseif field.fieldType == 'repeatingGrid' || field.fieldType == 'grid' %}
        <div class="grid g-2 nc-{{ field.columns|length }}">
            {% for column in field.columns %}
                {% set class = 'col-1-' ~ loop.length  %}
                {% if column.class %}
                    {% if 'col-' in column.class %}
                        {% set class = column.class %}
                    {% else %}
                        {% set class = class ~ ' ' ~ column.class %}
                    {% endif %}
                {% endif %}
                {% set class = class ~ ' w-100' %}
                <div class="{{ class }}">
                    {% for child in column.childFields %}
                        {% if child.fieldType in ["radio", "multiCheckbox", "checkbox"] %}
                            {% set child.groupId = random_letters() %}
                        {% endif %}
                        <div class="mb-2 {{ child.groupId ?: '' }}">
                            {{ _self.buildFieldLabel(child, 'FormLabel--block') }}
                            {{ _self.buildField(child) }}
                        </div>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>
    {% else %}
        {{ field.tag|replace({"error": "is-invalid"}) }}
    {% endif %}

    {# The groupId value is used for radio and checkbox field validation #}
    {% if field.groupId %}
        </div>
    {% endif %}

    {# Display the field description below the field if necessary #}
    {{ _self.buildFieldDescription(field, 'below') }}
{% endmacro %}

